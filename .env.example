# ---- Telegram ----
BOT_TOKEN=123456:ABC-your-botfather-token
# THE unified channel (add the bot as admin with Post messages first).
# Plain channel: -1001234567890 ; forum-supergroup topic: -1001234567890:17
# Extra posting targets are added at runtime with /addchannel.
CHANNEL_ID_MAIN=-1001111111111
# Comma-separated Telegram user IDs allowed to use admin commands
ADMIN_USER_IDS=11111111

# ---- Database (Supabase / Neon / local) ----
# Supabase: Settings -> Database -> Connection string (use the *session* pooler, port 5432).
# The app converts postgres:// to postgresql+asyncpg:// automatically.
DATABASE_URL=postgresql+asyncpg://postgres:password@db.xxxxxxxx.supabase.co:5432/postgres
# For the pure-local docker profile use:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/moonin

# ---- AI providers (all three; router fails over between them) ----
DEEPSEEK_API_KEY=sk-...
GROQ_API_KEY=gsk_...
GEMINI_API_KEY=AI...
# Requests-per-minute throttles kept BELOW free-tier limits
GROQ_RPM=25
DEEPSEEK_RPM=30
GEMINI_RPM=12

# ---- Webhook vs polling ----
USE_WEBHOOK=false
# Required when USE_WEBHOOK=true (your public https URL, e.g. https://moonin-bot.onrender.com)
WEBHOOK_BASE_URL=
WEBHOOK_SECRET=change-me-to-a-random-string
PORT=8080

# ---- Newsletter mailbox (IMAP) ----
NEWSLETTER_IMAP_HOST=imap.gmail.com
NEWSLETTER_IMAP_USER=your.dedicated.mailbox@gmail.com
# For Gmail: create an App Password (requires 2FA on the account)
NEWSLETTER_IMAP_PASSWORD=abcd efgh ijkl mnop

# ---- Scraping behaviour ----
# Optional HTTP(S) proxy for all scrapers (change IP with zero code edits). Leave empty to go direct.
SCRAPER_PROXY_URL=
# Separate optional proxy used only by the LinkedIn guest-page scraper
LINKEDIN_PROXY_URL=
LINKEDIN_ENABLED=true
# Playwright rendering for JS-heavy pages. Set false on 512MB hosts (Render free tier).
PLAYWRIGHT_ENABLED=true

# ---- Scheduler intervals ----
RSS_POLL_MINUTES=20
NEWSLETTER_POLL_MINUTES=15
WEB_SCRAPE_HOURS=4
COMMUNITY_SCRAPE_HOURS=4
LINKEDIN_SCRAPE_HOURS=6

# ---- Misc ----
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
LOG_LEVEL=INFO
TZ=Asia/Yerevan
